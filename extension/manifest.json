{
  "manifest_version": 3,
  "name": "Plutchik Emotion Lens",
  "version": "2.1.0",
  "description": "Privacy-first emotional subtext analysis for Reddit, Gmail, and LinkedIn.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.reddit.com/*",
    "*://mail.google.com/*",
    "*://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.reddit.com/*", "https://mail.google.com/*", "*://*.linkedin.com/*"],
      "js": ["src/content/content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "html/popup.html"
  },
  "options_page": "html/options.html"
}
