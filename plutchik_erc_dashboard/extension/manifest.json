{
  "manifest_version": 3,
  "name": "Plutchik Emotion Lens",
  "version": "2.1.0",
  "description": "Passive emotion overlay on web content (Reddit, LinkedIn, Gmail). Powered by Plutchik ERC.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*.reddit.com/*",
    "https://*.linkedin.com/*",
    "https://mail.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.reddit.com/*",
        "*://*.linkedin.com/*",
        "*://mail.google.com/*"
      ],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ]
}
